<%- include('partials/header') %>
<main>
    <div class="course-header">
        <h1><%= course.title %></h1>
        <p class="course-meta"><%= course.id %> • <%= course.credits %> credits</p>
        <p class="course-description"><%= course.description %></p>
    </div>


    <div class="sections">
        <div class="sections-intro">
            <h3 style="text-decoration: underline;">Sorting</h3>
            <% if (queryParams.sort === 'professor' || queryParams.sort === 'room' || queryParams.sort === 'time') { %>
                <div class="sort-message">
                    <p>Currently sorted by: <%= currentSort %></p>
                </div>
            <% } else { %>
                <div class="sort-message">
                    <p>No sorting applied, using default sorting by time.</p>
                </div>
            <% } %>
        <div class="sections-header">
            <p>Available Sections</p>
            <div class="sort-options">
                <span>Sort by: </span>
                <a href="/catalog/<%= course.id %>?sort=time" class="<%= currentSort === 'time' ? 'active' : '' %>">Time</a>
                <a href="/catalog/<%= course.id %>?sort=professor" class="<%= currentSort === 'professor' ? 'active' : '' %>">Professor</a>
                <a href="/catalog/<%= course.id %>?sort=room" class="<%= currentSort === 'room' ? 'active' : '' %>">Room</a>
            </div>
        </div>
    </div>

        <div class="section-list">
            <% course.sections.forEach(section => { %>
                <div class="section-card">
                    <div class="section-time"><%= section.time %></div>
                    <div class="section-room">Room: <%= section.room %></div>
                    <div class="section-professor">Instructor: <%= section.professor %></div>
                </div>
            <% }); %>
        </div>
    </div>

    <div class="navigation">
        <p><a href="/catalog">&larr; Back to Course Catalog</a></p>
    </div>
</main>
<%- include('partials/footer') %>